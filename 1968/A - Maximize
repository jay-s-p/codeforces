// Online C++ compiler to run C++ program online
#include <bits/stdc++.h>
using namespace std;
int main() {
    int n;
    cin>>n;
    for(int i=0; i<n; i++)
    {
        int x;
        cin>>x;
        int y=0;
        for(int j=(x/2)-1; j<x; j++)
        {
            
            int a=gcd(x,j);
            // cout<<a<<endl;
            if(a+j>y)
            {
                y=j;
            }
        }
        cout<<y<<endl;
    }
   
 
    return 0;
}